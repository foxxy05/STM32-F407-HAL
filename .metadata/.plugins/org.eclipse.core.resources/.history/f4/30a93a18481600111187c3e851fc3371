// ===================== MOTOR CONTROL =====================
void MotorInit(Motor_t *motor,	TIM_TypeDef *TIMx, uint32_t channelLeft, uint32_t channelRight,	int16_t maxPWM){
    motor->TIMx = TIMx;
    motor->channelLPWM = channelLeft;
    motor->channelRPWM = channelRight;
    motor->maxPWM = maxPWM;
}

void MotorSet(Motor_t *motor, int16_t speed){
    if (speed > motor->maxPWM)						speed = motor->maxPWM;
    else if (speed < -motor->maxPWM)				speed = -motor->maxPWM;

    volatile uint32_t *ccrLPWM = &motor->TIMx->CCR1 + (motor->channelLPWM - 1);
    volatile uint32_t *ccrRPWM = &motor->TIMx->CCR1 + (motor->channelRPWM - 1);

    if (speed >= 0){
        *ccrRPWM = speed;
        *ccrLPWM = 0;
    } else{
        *ccrRPWM = 0;
        *ccrLPWM = -speed;
    }
}

void KinematicsControl(RobotControl_t *robot){

	double theta = degree2radian(robot->currentAngle);
	robot->VxG = ( robot->Vx) * cosf(theta) + (robot->Vy) * sinf(theta);
	robot->VyG = (-robot->Vx) * sinf(theta) + (robot->Vy) * cosf(theta);

	robot->wLW = (int16_t)((-robot->VxG * oneBy2F) - (robot->VyG * sqrtThreeby2F) + (robot->Omega));				//LEFT
	robot->wRW = (int16_t)((-robot->VxG * oneBy2F) + (robot->VyG * sqrtThreeby2F) + (robot->Omega));				//RIGHT
	robot->wFW = (int16_t)(( robot->VxG ) + (robot->Omega));														//FRONT

	robot->wLW = constrain(robot->wLW, -MAX_PWM, MAX_PWM);
	robot->wRW = constrain(robot->wRW, -MAX_PWM, MAX_PWM);
	robot->wFW = constrain(robot->wFW, -MAX_PWM, MAX_PWM);

}

void KinematicsDrive(RobotControl_t *robot){
	MotorSet(&motorLW, robot->wLW);
	MotorSet(&motorRW, robot->wRW);
    MotorSet(&motorFW, robot->wFW);
}

// ===================== PID CONTROL =====================
void RobotUpdateAngle(RobotControl_t *robot){
    robot->currentAngle = IMU_TICK_HEADING;
}

float PIDCompute(PID_t *pid, float error){
    uint32_t currentTime = HAL_GetTick();
    float deltaT = (currentTime - pid->previousTime) / 1000.0f;

    if (deltaT <= 0.0f)		deltaT = 0.001f;

    pid->integral += error * deltaT;
    pid->integral = constrain(pid->integral, -50.0f, 50.0f);

    float proportional = error;
    float derivative = (error - pid->previousError) / deltaT;
    float integral = pid->integral;

    float PID = (pid->kp * proportional ) + (pid->kd * derivative) + (pid->ki * integral);
    PID = constrain(PID, -MAX_PWM, MAX_PWM);

    pid->previousError  = error;
    pid->previousTime   = currentTime;

    return PID;
}

void PIDReset(PID_t *pid){
    pid->integral = 0.0f;
    pid->previousError = 0.0f;
    pid->previousTime = HAL_GetTick();
}

