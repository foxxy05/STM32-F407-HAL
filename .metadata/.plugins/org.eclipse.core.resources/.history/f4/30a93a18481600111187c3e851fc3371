		Robot.Vy = LY;

		if (fabsf(Robot.Omega) < 5.0f) {
		    float error = NormalizeAngle(Robot.currentAngle - Robot.targetAngle);

		    if (fabsf(error) < 2.0f) {
		        Robot.Omega = 0;
		    } else {
		        Robot.Omega = -PIDCompute(&OmegaPID, error);
		    }
		} else {
		    Robot.targetAngle = Robot.currentAngle;
		    PIDReset(&OmegaPID);
		}

		KinematicsControl(&Robot);
		KinematicsDrive(&Robot);

